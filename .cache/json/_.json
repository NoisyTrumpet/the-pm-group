644c2051f5db1e5fcc20a3bd68fb/55218/csav.webp 116w,\n/static/2c63644c2051f5db1e5fcc20a3bd68fb/dc4ac/csav.webp 232w","type":"image/webp","sizes":"(min-width: 232px) 232px, 100vw"}]},"width":232,"height":83}}}}}]},"howWeGotHere":{"content":"<p><strong>The PM Group</strong> was started in 1988 and has become the largest media buyer in San Antonio for the last 20 years. As media and technology have dramatically changed, The PM Group has transformed and continues to reinvent ourselves every 5-7 years. That’s how you stay on top and retain clients for decades!</p>\n<p>&nbsp;</p>\n<p>Today, we are a focused group of affiliated San Antonio advertising companies, offering a complete range of marketing services.</p>\n","title":"HOW WE GOT HERE.","image":{"localFile":{"childImageSharp":{"gatsbyImageData":{"layout":"constrained","placeholder":{"fallback":"data:image/jpeg;base64,"},"images":{"fallback":{"src":"/static/d69de6d3471e8d4ea255f95bc7c7de72/be609/Book-of-list-cropped-1-2021-w2019-1536x765-1.png","srcSet":"/static/d69de6d3471e8d4ea255f95bc7c7de72/63ef2/Book-of-list-cropped-1-2021-w2019-1536x765-1.png 384w,\n/static/d69de6d3471e8d4ea255f95bc7c7de72/cf0ae/Book-of-list-cropped-1-2021-w2019-1536x765-1.png 768w,\n/static/d69de6d3471e8d4ea255f95bc7c7de72/be609/Book-of-list-cropped-1-2021-w2019-1536x765-1.png 1536w","sizes":"(min-width: 1536px) 1536px, 100vw"},"sources":[{"srcSet":"/static/d69de6d3471e8d4ea255f95bc7c7de72/3e982/Book-of-list-cropped-1-2021-w2019-1536x765-1.webp 384w,\n/static/d69de6d3471e8d4ea255f95bc7c7de72/0d88f/Book-of-list-cropped-1-2021-w2019-1536x765-1.webp 768w,\n/static/d69de6d3471e8d4ea255f95bc7c7de72/0081b/Book-of-list-cropped-1-2021-w2019-1536x765-1.webp 1536w","type":"image/webp","sizes":"(min-width: 1536px) 1536px, 100vw"}]},"width":1536,"height":765}}}}},"primaryCta":{"ctaLink":{"url":"/contact-us/"},"ctaText":"Connect","primaryCtaFields":[{"title":"Advertising","link":"/our-work"},{"title":"Digital Marketing","link":"/our-work"},{"title":"Creative & Video Production","link":"/our-work"},{"title":"Public Relations","link":"/our-work"},{"title":"Events","link":"/our-work"},{"title":"Media Buying","link":"/media-buying"}]},"secondaryCta":{"title":"SHARED KNOWLEDGE. SHARED RESOURCES. SHARED SUCCESS.","link":null,"image":{"localFile":{"childImageSharp":{"gatsbyImageData":{"layout":"constrained","placeholder":{"fallback":"data:image/jpeg;base64,"},"images":{"fallback":{"src":"/static/76ada9df25c28e2fa8e94b2be29b9619/ba085/building.retouched.png","srcSet":"/static/76ada9df25c28e2fa8e94b2be29b9619/3ec4f/building.retouched.png 475w,\n/static/76ada9df25c28e2fa8e94b2be29b9619/b33a4/building.retouched.png 950w,\n/static/76ada9df25c28e2fa8e94b2be29b9619/ba085/building.retouched.png 1900w","sizes":"(min-width: 1900px) 1900px, 100vw"},"sources":[{"srcSet":"/static/76ada9df25c28e2fa8e94b2be29b9619/899be/building.retouched.webp 475w,\n/static/76ada9df25c28e2fa8e94b2be29b9619/f5935/building.retouched.webp 950w,\n/static/76ada9df25c28e2fa8e94b2be29b9619/664ab/building.retouched.webp 1900w","type":"image/webp","sizes":"(min-width: 1900px) 1900px, 100vw"}]},"width":1900,"height":1450.9999999999998}}}}},"subcaption":"A constellation of marketing services, together in one place.","services":{"ctaLink":{"url":"/our-work"},"ctaText":"See our work","serviceEntry":[{"content":"<p>The PM Group is the largest advertising agency in San Antonio, offering marketing, branding, and creative services. We are also the largest buyer of media in San Antonio and South Texas, with unsurpassed media clout in television, radio, outdoor, digital and print advertising.</p>\n","icon":"moon","title":"Traditional Advertising"},{"content":"<p>We create effective digital marketing strategies and solutions for our clients including online media plans, SEO, social media plans, and websites.</p>\n","icon":"moon","title":"Digital Marketing"},{"content":"<p>The PM Group has an award-winning creative team, in house, who can craft the right expression for your brand in any media. You don’t stay on-top for 32+ years unless you are getting your clients the results they expect!</p>\n","icon":"moon","title":"Creative"},{"content":"<p>Quarter Moon Productions is our full-service production studio, with state-of-the-art equipment, staffed with talented editors, producers, motion graphic artists and directors. We create television &amp; radio commercials, tv shows, and brand videos for our clients.</p>\n","icon":"moon","title":"Video Content Creation"},{"content":"<p>In just three short years, Noisy Trumpet Digital &amp; Public Relations became the second largest PR firm in South Texas! Hard work plus great, talented staffers have lead the firm to receive numerous national awards &amp; recognition!</p>\n","icon":"moon","title":"Public Relations"},{"content":"<p>The PM Group is a national leader in philanthropic and special event marketing including PSA campaigns, pop culture events like Celebrity Fan Fest, The King &amp; Queen of Good Hearts Gala, Charitable Poker Tournaments, Charitable Golf Tournaments and High School Football bowl games. In addition, we partner with national and local brands on sales growth promotions for clients that puts smiles on the faces of our clients!</p>\n","icon":"moon","title":"Events, Promos and Fundraisers"}]},"headline":"San Antonio’s Largest Advertising and Marketing Agency","aboutSection":{"title":"FULL-SERVICE MARKETING","content":"<p class=\"x-el x-el-span c1-ba c1-bb c1-b c1-bc c1-bd c1-be c1-bf c1-bg x-d-ux\">The PM Group is a San Antonio advertising agency that operates as the hub of a <a href=\"/companies/\"><strong>group of advertising companies</strong></a> under the same ownership.</p>\n<p>&nbsp;</p>\n<p class=\"x-el x-el-span c1-ba c1-bb c1-b c1-bc c1-bd c1-be c1-bf c1-bg x-d-ux\">Each advertising company has its own defined specialty of marketing services. Together, we bring our skills, strengths, and resources to <strong><a href=\"/capabilities/\">help our clients</a></strong>.</p>\n<p>&nbsp;</p>\n<p class=\"x-el x-el-span c1-ba c1-bb c1-b c1-bc c1-bd c1-be c1-bf c1-bg x-d-ux\">By sharing information and resources within our constellation of companies, we can work smarter, FASTER, and more cost-efficiently.</p>\n","image":{"localFile":{"childImageSharp":{"gatsbyImageData":{"layout":"constrained","placeholder":{"fallback":"data:image/jpeg;base64,"},"images":{"fallback":{"src":"/static/36588b9075d6038c9a89554f54fbcdcb/52ec6/pmgAbstract_home.png","srcSet":"/static/36588b9075d6038c9a89554f54fbcdcb/c5265/pmgAbstract_home.png 364w,\n/static/36588b9075d6038c9a89554f54fbcdcb/40cce/pmgAbstract_home.png 728w,\n/static/36588b9075d6038c9a89554f54fbcdcb/52ec6/pmgAbstract_home.png 1455w","sizes":"(min-width: 1455px) 1455px, 100vw"},"sources":[{"srcSet":"/static/36588b9075d6038c9a89554f54fbcdcb/96e50/pmgAbstract_home.webp 364w,\n/static/36588b9075d6038c9a89554f54fbcdcb/f4596/pmgAbstract_home.webp 728w,\n/static/36588b9075d6038c9a89554f54fbcdcb/f5783/pmgAbstract_home.webp 1455w","type":"image/webp","sizes":"(min-width: 1455px) 1455px, 100vw"}]},"width":1455,"height":800}},"childrenImageSharp":[{"gatsbyImageData":{"layout":"constrained","placeholder":{"fallback":"data:image/jpeg;base64,"},"images":{"fallback":{"src":"/static/36588b9075d6038c9a89554f54fbcdcb/52ec6/pmgAbstract_home.png","srcSet":"/static/36588b9075d6038c9a89554f54fbcdcb/c5265/pmgAbstract_home.png 364w,\n/static/36588b9075d6038c9a89554f54fbcdcb/40cce/pmgAbstract_home.png 728w,\n/static/36588b9075d6038c9a89554f54fbcdcb/52ec6/pmgAbstract_home.png 1455w","sizes":"(min-width: 1455px) 1455px, 100vw"},"sources":[{"srcSet":"/static/36588b9075d6038c9a89554f54fbcdcb/96e50/pmgAbstract_home.webp 364w,\n/static/36588b9075d6038c9a89554f54fbcdcb/f4596/pmgAbstract_home.webp 728w,\n/static/36588b9075d6038c9a89554f54fbcdcb/f5783/pmgAbstract_home.webp 1455w","type":"image/webp","sizes":"(min-width: 1455px) 1455px, 100vw"}]},"width":1455,"height":800}}]}}},"contactSection":{"body":"We love helping businesses by creating individualized marketing plans that will help them reach their goals. Contact us today to see what we can do for you.","fieldGroupName":"contact_section","title":"Get in Touch To Learn More","name":"Fran Yanity","position":"President & COO","phoneNumber":"(210) 490-2554","email":"fran.yanity@thepmgrp.com","blurb":"The PM Group","franPhoto":{"localFile":{"childImageSharp":{"gatsbyImageData":{"layout":"constrained","placeholder":{"fallback":"data:image/jpeg;base64,"},"images":{"fallback":{"src":"/static/756604fdf7867bfa413075d087047663/0e178/fran.png","srcSet":"/static/756604fdf7867bfa413075d087047663/b579e/fran.png 75w,\n/static/756604fdf7867bfa413075d087047663/1db4f/fran.png 150w,\n/static/756604fdf7867bfa413075d087047663/0e178/fran.png 300w","sizes":"(min-width: 300px) 300px, 100vw"},"sources":[{"srcSet":"/static/756604fdf7867bfa413075d087047663/7572c/fran.webp 75w,\n/static/756604fdf7867bfa413075d087047663/4bee1/fran.webp 150w,\n/static/756604fdf7867bfa413075d087047663/78de2/fran.webp 300w","type":"image/webp","sizes":"(min-width: 300px) 300px, 100vw"}]},"width":300,"height":300}}}}}}}},"pageContext":{"breadcrumb":{"location":"/","crumbs":[{"pathname":"/","crumbLabel":"Home"}]}}}