671e/8fa94/Screen-Shot-2015-08-28-at-6.39.19-AM-e1440764108658-1.webp 75w,\n/static/c2a91c24e58f24f0818cbf778db7671e/cba1b/Screen-Shot-2015-08-28-at-6.39.19-AM-e1440764108658-1.webp 150w,\n/static/c2a91c24e58f24f0818cbf778db7671e/93dd2/Screen-Shot-2015-08-28-at-6.39.19-AM-e1440764108658-1.webp 300w","type":"image/webp","sizes":"(min-width: 300px) 300px, 100vw"}]},"width":300,"height":181}}}}}},{"categories":{"nodes":[{"name":"Agency News"}]},"title":"For Those Hot Summer Days – A&E Air Conditioning Gets You Cool!","slug":"for-those-hot-summer-days-ae-air-conditioning-gets-you-cool","featuredImage":{"node":{"localFile":{"childImageSharp":{"gatsbyImageData":{"layout":"constrained","placeholder":{"fallback":"data:image/png;base64,"},"images":{"fallback":{"src":"/static/1dd53235bd6f0f166f3bbccc3f909542/5329f/a-e-airconditioning-heating-llc_v2-e1438171272488-1.png","srcSet":"/static/1dd53235bd6f0f166f3bbccc3f909542/be7c0/a-e-airconditioning-heating-llc_v2-e1438171272488-1.png 75w,\n/static/1dd53235bd6f0f166f3bbccc3f909542/5d6b7/a-e-airconditioning-heating-llc_v2-e1438171272488-1.png 150w,\n/static/1dd53235bd6f0f166f3bbccc3f909542/5329f/a-e-airconditioning-heating-llc_v2-e1438171272488-1.png 300w","sizes":"(min-width: 300px) 300px, 100vw"},"sources":[{"srcSet":"/static/1dd53235bd6f0f166f3bbccc3f909542/8fa94/a-e-airconditioning-heating-llc_v2-e1438171272488-1.webp 75w,\n/static/1dd53235bd6f0f166f3bbccc3f909542/cba1b/a-e-airconditioning-heating-llc_v2-e1438171272488-1.webp 150w,\n/static/1dd53235bd6f0f166f3bbccc3f909542/93dd2/a-e-airconditioning-heating-llc_v2-e1438171272488-1.webp 300w","type":"image/webp","sizes":"(min-width: 300px) 300px, 100vw"}]},"width":300,"height":181}}}}}}]}}]}},"pageContext":{"id":"cG9zdDo5MTQ=","content":"<p>What do you get when a client has such good professional service that they seem to be able to pull off almost anything? You create a television campaign that says their guys (and women) are magicians.<br /> <br />This is exactly what The PM Group did when we created one of two :30 television commercials for our newest client A&amp;E Air Conditioning and Heating L.L.C.<br /> <br />The commercials were released along with the new <a href=\"https://ae4cool.com\">A&amp;E Air Conditioning and Heating website</a>. The PM Group will continue doing broadcast and web advertising for A&amp;E.<br /> <br />Watch the “Magician” commercial below. </p>\n\n<figure class=\"wp-block-embed is-type-video is-provider-youtube wp-block-embed-youtube wp-embed-aspect-16-9 wp-has-aspect-ratio\"><div class=\"wp-block-embed__wrapper\">\n<iframe title=\"A&amp;E Magician\" width=\"750\" height=\"422\" src=\"https://www.youtube.com/embed/StO9jRmZBdU?feature=oembed\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" allowfullscreen></iframe>\n</div></figure>\n\n\n<p></p>\n","title":"It’s Magic","seo":{"breadcrumbs":[{"text":"It’s Magic","url":"/its-magic/"}],"title":"New Commercial for A&E Air Conditioning and Heating | PMG","metaDesc":"The PM Group, San Antonio and South Texas' largest advertising agency, has created a magic TV campaign for A&E Air Conditioning and Heating.","focuskw":"magic","metaKeywords":"","metaRobotsNoindex":"index","metaRobotsNofollow":"follow","opengraphTitle":"New Commercial for A&E Air Conditioning and Heating | PMG","opengraphDescription":"The PM Group, San Antonio and South Texas' largest advertising agency, has created a magic TV campaign for A&E Air Conditioning and Heating.","opengraphImage":{"altText":"A&E Air Conditioning & Heating L.L.C.'s New Magician Commercial","sourceUrl":"https://thepmgroup.flywheelsites.com/wp-content/uploads/2015/06/Screen-Shot-2015-06-01-at-1.36.17-PM-e1433184377641-1.png","srcSet":null},"twitterTitle":"","twitterDescription":"","twitterImage":null,"canonical":"/its-magic/","cornerstone":false,"schema":{"raw":"{\"@context\":\"https://schema.org\",\"@graph\":[{\"@type\":\"WebSite\",\"@id\":\"/#website\",\"url\"