f/Image-12.7.20-PMG-Ongoing-Fundraising-Efforts.png 300w,\n/static/3786cbf317784cdd24d8464b2272cb71/6d090/Image-12.7.20-PMG-Ongoing-Fundraising-Efforts.png 600w,\n/static/3786cbf317784cdd24d8464b2272cb71/e4495/Image-12.7.20-PMG-Ongoing-Fundraising-Efforts.png 1200w","sizes":"(min-width: 1200px) 1200px, 100vw"},"sources":[{"srcSet":"/static/3786cbf317784cdd24d8464b2272cb71/93dd2/Image-12.7.20-PMG-Ongoing-Fundraising-Efforts.webp 300w,\n/static/3786cbf317784cdd24d8464b2272cb71/336f1/Image-12.7.20-PMG-Ongoing-Fundraising-Efforts.webp 600w,\n/static/3786cbf317784cdd24d8464b2272cb71/77a67/Image-12.7.20-PMG-Ongoing-Fundraising-Efforts.webp 1200w","type":"image/webp","sizes":"(min-width: 1200px) 1200px, 100vw"}]},"width":1200,"height":723}}}}}}]}}]}},"pageContext":{"id":"cG9zdDo2MzA3OA==","content":"\n<div class=\"wp-block-image\"><figure class=\"aligncenter size-large\"><span class=\"wp-image-60350 inline-gatsby-image-wrapper gatsby-image-wrapper\" style=\"position:relative;overflow:hidden;max-width:100%;width:1024px\" data-reactroot=\"\"><span aria-hidden=\"true\" style=\"width:100%;padding-bottom:52.734375%\"></span><img aria-hidden=\"true\" src=\"data:image/png;base64,\" alt=\"\" style=\"position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;object-position:center;opacity:0;transition-delay:500ms\"/><picture><source srcSet=\"/static/b332d2a6f88c9c7a167f51d96dc92fa5/85b06/1-1024x538.png 256w,\n/static/b332d2a6f88c9c7a167f51d96dc92fa5/bc282/1-1024x538.png 512w,\n/static/b332d2a6f88c9c7a167f51d96dc92fa5/f1720/1-1024x538.png 1024w\" sizes=\"(max-width: 1024px) 100vw, 1024px\"/><img sizes=\"(max-width: 1024px) 100vw, 1024px\" srcSet=\"/static/b332d2a6f88c9c7a167f51d96dc92fa5/85b06/1-1024x538.png 256w,\n/static/b332d2a6f88c9c7a167f51d96dc92fa5/bc282/1-1024x538.png 512w,\n/static/b332d2a6f88c9c7a167f51d96dc92fa5/f1720/1-1024x538.png 1024w\" src=\"/static/b332d2a6f88c9c7a167f51d96dc92fa5/f1720/1-1024x538.png\" alt=\"\" loading=\"eager\" style=\"position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;object-position:center;opacity:1;transition:opacity 500ms\"/></picture><noscript><picture><source srcset=\"/static/b332d2a6f88c9c7a167f51d96dc92fa5/85b06/1-1024x538.png 256w,\n/static/b332d2a6f88c9c7a167f51d96dc92fa5/bc282/1-1024x538.png 512w,\n/static/b332d2a6f88c9c7a167f51d96dc92fa5/f1720/1-1024x538.png 1024w\" sizes=\"(max-width: 1024px) 100vw, 1024px\" /><img loading=\"eager\" sizes=\"(max-width: 1024px) 100vw, 1024px\" srcset=\"/static/b332d2a6f88c9c7a167f51d96dc92fa5/85b06/1-1024x538.png 256w,\n/static/b332d2a6f88c9c7a167f51d96dc92fa5/bc282/1-1024x538.png 512w,\n/static/b332d2a6f88c9c7a167f51d96dc92fa5/f1720/1-1024x538.png 1024w\" src=\"/static/b332d2a6f88c9c7a167f51d96dc92fa5/f1720/1-1024x538.png\" alt=\"\" style=\"position:absolute;top:0;left:0;opacity:1;width:100%;height:100%;object-fit:cover;object-position:center\"/></picture></noscript></span><figcaption>The PM Group’s President / COO Fran Yanity presents San Antonio Sports $60,000 from the event proceeds.</figcaption></figure></div>\n\n\n\n<div style=\"height:50px\" aria-hidden=\"true\" class=\"wp-block-spacer\"></div>\n\n\n\n<p>Thank you never feels like enough when we can make such a positive impact on community nonprofits like what we have been able to do already this year! &nbsp;</p>\n\n\n\n<div style=\"height:50px\" aria-hidden=\"true\" class=\"wp-block-spacer\"></div>\n\n\n\n<p>Here at <a href=\"https://thepmgrp.com/about/\"><strong>The PM Group</strong></a> offices, we presented <a href=\"https://sanantoniosports.org/\"><strong>San Antonio Sports</strong></a> and <a href=\"http://www.sayes.org\"><strong>SA YES</strong></a> with the funds we raised to help them continue their missions in our community. Both organizations work hard to support youth in San Antonio with needed school supplies for kids to be productive in school and teaching them empowering and foundational lessons through the power of sport.</p>\n\n\n\n<div style=\"height:50px\" aria-hidden=\"true\" class=\"wp-block-spacer\"></div>\n\n\n\n<p>The funds were raised at a January 16<sup>th</sup> Charity Texas Hold’em Poker Tournament benefitting both organizations.</p>\n\n\n\n<div style=\"height:50px\" aria-hidden=\"true\" class=\"wp-block-spacer\"></div>\n\n\n\n<div class=\"wp-block-image\"><figure class=\"aligncenter size-large\"><span class=\"wp-image-60356 inline-gatsby-image-wrapper gatsby-image-wrapper\" style=\"position:relative;overflow:hidden;max-width:100%;width:700px\" data-reactroot=\"\"><span aria-hidden=\"true\" style=\"width:100%;padding-bottom:100%\"></span><img aria-hidden=\"true\" src=\"data:image/png;base64,\" alt=\"\" style=\"position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;object-position:center;opacity:0;transition-delay:500ms\"/><picture><source srcSet=\"/static/df3412fa22709bcbad6ff67c2031a143/1aaec/1-2.png 175w,\n/static/df3412fa22709bcbad6ff67c2031a143/98287/1-2.png 350w,\n/static/df3412fa22709bcbad6ff67c2031a143/39600/1-2.png 700w\" sizes=\"(max-width: 700px) 100vw, 700px\"/><img sizes=\"(max-width: 700px) 100vw, 700px\" srcSet=\"/static/df3412fa22709bcbad6ff67c2031a143/1aaec/1-2.png 175w,\n/static/df3412fa22709bcbad6ff67c2031a143/98287/1-2.png 350w,\n/static/df3412fa22709bcbad6ff67c2031a143/39600/1-2.png 700w\" src=\"/static/df3412fa22709bcbad6ff67c2031a143/39600/1-2.png\" alt=\"SA YES Receives Donation from The PM Group | San Antonio Advertising Agency\" loading=\"eager\" style=\"position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;object-position:center;opacity:1;transition:opacity 500ms\"/></picture><noscript><picture><source srcset=\"/static/df3412fa22709bcbad6ff67c2031a143/1aaec/1-2.png 175w,\n/static/df3412fa22709bcbad6ff67c2031a143/98287/1-2.png 350w,\n/static/df3412fa22709bcbad6ff67c2031a143/39600/1-2.png 700w\" sizes=\"(max-width: 700px) 100vw, 700px\" /><img loading=\"eager\" sizes=\"(max-width: 700px) 100vw, 700px\" srcset=\"/static/df3412fa22709bcbad6ff67c2031a143/1aaec/1-2.png 175w,\n/static/df3412fa22709bcbad6ff67c2031a143/98287/1-2.png 350w,\n/static/df3412fa22709bcbad6ff67c2031a143/39600/1-2.png 700w\" src=\"/static/df3412fa22709bcbad6ff67c2031a143/39600/1-2.png\" alt=\"SA YES Receives Donation from The PM Group | San Antonio Advertising Agency\" style=\"position:absolute;top:0;left:0;opacity:1;width:100%;height:100%;object-fit:cover;object-position:center\"/></picture></noscript></span><figcaption>The PM Group’s President / COO Fran Yanity presents SA YES $27,500 from the event proceeds.</figcaption></figure></div>\n\n\n\n<div style=\"height:50px\" aria-hidden=\"true\" class=\"wp-block-spacer\"></div>\n\n\n\n<p>“<em>We are so thankful for the amazing financial support we receive annually from The PM Group’s incredible fundraising efforts</em>,” stated San Antonio Sports CEO, Russ Bookbinder.</p>\n\n\n\n<div style=\"height:50px\" aria-hidden=\"true\" class=\"wp-block-spacer\"></div>\n\n\n\n<p>“<em>Our San Antonio-based advertising agency team raised over $1,050,000 in support of area nonprofits that needed our help in 2020. Hopefully, we can top that number in 2021,</em>” stated The PM Group’s President, Fran Yanity. In addition to San Antonio, the advertising agency has satellite offices in Arizona, Virginia, and Massachusetts.&nbsp;&nbsp; &nbsp;&nbsp;&nbsp;</p>\n\n\n\n<div style=\"height:50px\" aria-hidden=\"true\" class=\"wp-block-spacer\"></div>\n\n\n\n<p><strong>More to Come in 2021</strong></p>\n\n\n\n<p>The PM Group will be hosting several additional Charity Texas Hold’em Poker Tournaments throughout 2021 and you can help us support local nonprofits. You can register now for the next tournament, the <em>Final Five Charity Poker Showdown</em>, which will be held on Saturday April 3, 2021 at the Crown Ridge Banquet Hall. Visit <a href=\"https://texasholdemsa.com/\"><strong>texasholdemsa.com</strong></a> to learn more.</p>\n\n\n\n<div style=\"height:100px\" aria-hidden=\"true\" class=\"wp-block-spacer\"></div>\n\n\n\n<p><a href=\"https://thepmgrp.com/\"><strong>About The PM Group</strong></a>: The PM Group was founded in 1988. For over 33 years, the agency has continued to grow and is San Antonio’s largest advertising agency. The PM Group’s client roster spans numerous industries including automotive, CPG, entertainment and sports marketing, legal, business services, non-profits, real estate and fitness. For two consecutive years now, the Agency has set annual revenue records with the addition of six new clients in 2020 and through their ongoing success with our existing clients. Additionally, the agency hosts their annual Charity Gala every year &#8212;that to date&#8211; has raised millions of dollars for local San Antonio area non-profit organizations in the last 15 years! In 2020 alone, the Agency donated over $1,050,000 to local non-profits. It is our way of giving back to the community that we so humbly serve.</p>\n","title":"The PM Group Raises $87,500 for Two Local Charities","seo":{"breadcrumbs":[{"text":"The PM Group Raises $87,500 for Two Local Charities","url":"/the-pm-group-raises-87500-for-two-local-charities/"}],"title":"The PM Group Raises $87,500 for Two Local Charities | The PM Group","metaDesc":"Here at The PM Group offices, we presented San Antonio Sports and SA YES with the funds we raised to help them continue their missions...","focuskw":"San Antonio Sports","metaKeywords":"","metaRobotsNoindex":"index","metaRobotsNofollow":"follow","opengraphTitle":"The PM Group Raises $87,500 for Two Local Charities | The PM Group","opengraphDescription":"Here at The PM Group offices, we presented San Antonio Sports and SA YES with the funds we raised to help them continue their missions...","opengraphImage":null,"twitterTitle":"","twitterDescription":"","twitterImage":{"altText":"San Antonio Sports Receives Donation from The PM Group | San Antonio Advertising Agency","sourceUrl":"https://thepmgroup.flywheelsites.com/wp-content/uploads/2021/02/2.png","srcSet":"https://the