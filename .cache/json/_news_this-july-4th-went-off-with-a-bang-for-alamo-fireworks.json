ax-width:100%;width:400px\" data-reactroot=\"\"><span aria-hidden=\"true\" style=\"width:100%;padding-bottom:100%\"></span><img aria-hidden=\"true\" src=\"data:image/jpeg;base64,\" alt=\"\" style=\"position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;object-position:center;opacity:0;transition-delay:500ms\"/><picture><source srcSet=\"/static/b5aff28f84a0a9c19b0b27bbce819a7e/d634c/shelter_in_place_400x400_FullPack_Recolor-1.jpg 100w,\n/static/b5aff28f84a0a9c19b0b27bbce819a7e/16d62/shelter_in_place_400x400_FullPack_Recolor-1.jpg 200w,\n/static/b5aff28f84a0a9c19b0b27bbce819a7e/27ec1/shelter_in_place_400x400_FullPack_Recolor-1.jpg 400w\" sizes=\"(max-width: 400px) 100vw, 400px\"/><img sizes=\"(max-width: 400px) 100vw, 400px\" srcSet=\"/static/b5aff28f84a0a9c19b0b27bbce819a7e/d634c/shelter_in_place_400x400_FullPack_Recolor-1.jpg 100w,\n/static/b5aff28f84a0a9c19b0b27bbce819a7e/16d62/shelter_in_place_400x400_FullPack_Recolor-1.jpg 200w,\n/static/b5aff28f84a0a9c19b0b27bbce819a7e/27ec1/shelter_in_place_400x400_FullPack_Recolor-1.jpg 400w\" src=\"/static/b5aff28f84a0a9c19b0b27bbce819a7e/27ec1/shelter_in_place_400x400_FullPack_Recolor-1.jpg\" alt=\"\" loading=\"eager\" style=\"position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;object-position:center;opacity:1;transition:opacity 500ms\"/></picture><noscript><picture><source srcset=\"/static/b5aff28f84a0a9c19b0b27bbce819a7e/d634c/shelter_in_place_400x400_FullPack_Recolor-1.jpg 100w,\n/static/b5aff28f84a0a9c19b0b27bbce819a7e/16d62/shelter_in_place_400x400_FullPack_Recolor-1.jpg 200w,\n/static/b5aff28f84a0a9c19b0b27bbce819a7e/27ec1/shelter_in_place_400x400_FullPack_Recolor-1.jpg 400w\" sizes=\"(max-width: 400px) 100vw, 400px\" /><img loading=\"eager\" sizes=\"(max-width: 400px) 100vw, 400px\" srcset=\"/static/b5aff28f84a0a9c19b0b27bbce819a7e/d634c/shelter_in_place_400x400_FullPack_Recolor-1.jpg 100w,\n/static/b5aff28f84a0a9c19b0b27bbce819a7e/16d62/shelter_in_place_400x400_FullPack_Recolor-1.jpg 200w,\n/static/b5aff28f84a0a9c19b0b27bbce819a7e/27ec1/shelter_in_place_400x400_FullPack_Recolor-1.jpg 400w\" src=\"/static/b5aff28f84a0a9c19b0b27bbce819a7e/27ec1/shelter_in_place_400x400_FullPack_Recolor-1.jpg\" alt=\"\" style=\"position:absolute;top:0;left:0;opacity:1;width:100%;height:100%;object-fit:cover;object-position:center\"/></picture></noscript></span></figure></li><li class=\"blocks-gallery-item\"><figure><span class=\"wp-image-60102 inline-gatsby-image-wrapper gatsby-image-wrapper\" style=\"position:relative;overflow:hidden;max-width:100%;width:800px\" data-reactroot=\"\"><span aria-hidden=\"true\" style=\"width:100%;padding-bottom:100%\"></span><img aria-hidden=\"true\" src=\"data:image/png;base64,\" alt=\"\" style=\"position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;object-position:center;opacity:0;transition-delay:500ms\"/><picture><source srcSet=\"/static/c91d1f8c1c69c2148cfe225ff7b3ea1a/f8f3a/1-1.png 200w,\n/static/c91d1f8c1c69c2148cfe225ff7b3ea1a/6a8a8/1-1.png 400w,\n/static/c91d1f8c1c69c2148cfe225ff7b3ea1a/7842b/1-1.png 800w\" sizes=\"(max-width: 800px) 100vw, 800px\"/><img sizes=\"(max-width: 800px) 100vw, 800px\" srcSet=\"/static/c91d1f8c1c69c2148cfe225ff7b3ea1a/f8f3a/1-1.png 200w,\n/static/c91d1f8c1c69c2148cfe225ff7b3ea1a/6a8a8/1-1.png 400w,\n/static/c91d1f8c1c69c2148cfe225ff7b3ea1a/7842b/1-1.png 800w\" src=\"/static/c91d1f8c1c69c2148cfe225ff7b3ea1a/7842b/1-1.png\" alt=\"\" loading=\"eager\" style=\"position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;object-position:center;opacity:1;transition:opacity 500ms\"/></picture><noscript><picture><source srcset=\"/static/c91d1f8c1c69c2148cfe225ff7b3ea1a/f8f3a/1-1.png 200w,\n/static/c91d1f8c1c69c2148cfe225ff7b3ea1a/6a8a8/1-1.png 400w,\n/static/c91d1f8c1c69c2148cfe225ff7b3ea1a/7842b/1-1.png 800w\" sizes=\"(max-width: 800px) 100vw, 800px\" /><img loading=\"eager\" sizes=\"(max-width: 800px) 100vw, 800px\" srcset=\"/static/c91d1f8c1c69c2148cfe225ff7b3ea1a/f8f3a/1-1.png 200w,\n/static/c91d1f8c1c69c2148cfe225ff7b3ea1a/6a8a8/1-1.png 400w,\n/static/c91d1f8c1c69c2148cfe225ff7b3ea1a/7842b/1-1.png 800w\" src=\"/static/c91d1f8c1c69c2148cfe225ff7b3ea1a/7842b/1-1.png\" alt=\"\" style=\"position:absolute;top:0;left:0;opacity:1;width:100%;height:100%;object-fit:cover;object-position:center\"/></picture></noscript></span></figure></li></ul></figure>\n\n\n\n<div style=\"height:50px\" aria-hidden=\"true\" class=\"wp-block-spacer\"></div>\n\n\n\n<p>Even with the curveballs of a pandemic environment, Alamo Fireworks still helped customers light up the skies this 4th of July and flew past their sky-high goals for the summer season. We’re excited to be keeping the spark lit as we start preparing to send off 2020 with a bang during the upcoming New Year festivities.</p>\n\n\n\n<div style=\"height:100px\" aria-hidden=\"true\" class=\"wp-block-spacer\"></div>\n\n\n\n<p><a href=\"https://thepmgrp.com/\"><strong>About The PM Group</strong></a>: The PM Group was founded in 1988. For over 32 years, the agency has continued to grow and is San Antonio’s largest advertising agency. The PM Group’s client roster spans numerous industries including automotive, CPG, entertainment and sports marketing, legal, business services, non-profit, real estate and fitness. In addition, the agency hosts an annual Charity Gala that to date has raised millions of dollars for local San Antonio area non-profit organizations in the last 15 years! In the past 10 years, The PM Group has raised both directly and indirectly over $12 million for these charities. It is our way of giving back to the community that we so humbly serve.</p>\n","title":"This July 4th Went Off With a Bang for Alamo Fireworks","seo":{"breadcrumbs":[{"text":"This July 4th Went Off With a Bang for Alamo Fireworks","url":"/this-july-4th-went-off-with-a-bang-for-alamo-fireworks/"}],"title":"This July 4th Went Off With a Bang for Alamo Fireworks | The PM Group","metaDesc":"Their summer campaign included audio streaming, a poppin’ segment on YOLO TX, a boomin’ social media push and digital campaign, new signage...","focuskw":"Alamo Fireworks","metaKeywords":"","metaRobotsNoindex":"index","metaRobotsNofollow":"follow","opengraphTitle":"This July 4th Went Off With a Bang for Alamo Fireworks | The PM Group","opengraphDescription":"Their summer campaign included audio streaming, a poppin’ segment on YOLO TX, a boomin’ social media push and digital campaign, new signage...","opengraphImage":{"altText":"Alamo Fireworks - The PM Group","sourceUrl":"https://thepmgroup.flywheelsites.com/wp-content/uploads/2020/09/1.png","srcSet":"https://thepmgroup.flywheelsites.com/wp-content/uploads/2020/09/1-300x158.png 300w, https://thepmgroup.flywheelsites.com/wp-content/uploads/2020/09/1-1024x538.png 1024w, https://thepmgroup.flywheelsites.com/wp-content/uploads/2020/09/1-768x403.png 768w, https://thepmgroup.flywheelsites.com/wp-content/uploads/2020/09/1.png 1200w"},"twitterTitle":"","twitterDescription":"","twitterImage":null,"canonical":"/this-july-4th-went-off-with-a-bang-for-alamo-fireworks/","cornerstone":false,"schema":{"raw":"{\"@context\":\"https://schema.org\",\"@graph\":[{\"@type\":\"WebSite\",\"@id\":\"/#website\",\"url\":\"/\",\"name\":\"The PM Group\",\"description\":\"San Antonio\\u2019s Largest Advertising and Marketing Agency\",\"potentialAction\":[{\"@type\":\"SearchAction\",\"target\":{\"@type\":\"EntryPoint\",\"urlTemplate\":\"/?s={search_term_string}\"},\"query-input\":\"required name=search_term_string\"}],\"inLanguage\":\"en-US\"},{\"@type\":\"ImageObject\",\"@id\":\"/this-july-4th-went-off-with-a-bang-for-alamo-fireworks/#primaryimage\",\"inLanguage\":\"en-US\",\"url\":\"/static/7fd04f651e27098a62d323c5fd76269c/1.png\",\"contentUrl\":\"/static/7fd04f651e27098a62d323c5fd76269c/1.png\",\"width\":1200,\"height\":630,\"caption\":\"Alamo Fireworks - The PM Group\"},{\"@type\":\"WebPage\",\"@id\":\"/this-july-4th-went-off-with-a-bang-for-alamo-fireworks/#webpage\",\"url\":\