{"data":{"allWpPost":{"nodes":[{"related_posts":{"nodes":[{"categories":{"nodes":[{"name":"Agency News"}]},"title":"Not All Ads Are Created Equal","slug":"not-ads-created-equal","featuredImage":{"node":{"localFile":{"childImageSharp":{"gatsbyImageData":{"layout":"constrained","placeholder":{"fallback":"data:image/png;base64,"},"images":{"fallback":{"src":"/static/d59b264d80d993de7ecb89471c8b5ac9/9ffbb/Image-1.24.18-new-consumer-research-square.png","srcSet":"/static/d59b264d80d993de7ecb89471c8b5ac9/0f420/Image-1.24.18-new-consumer-research-square.png 200w,\n/static/d59b264d80d993de7ecb89471c8b5ac9/dfd8e/Image-1.24.18-new-consumer-research-square.png 400w,\n/static/d59b264d80d993de7ecb89471c8b5ac9/9ffbb/Image-1.24.18-new-consumer-research-square.png 800w","sizes":"(min-width: 800px) 800px, 100vw"},"sources":[{"srcSet":"/static/d59b264d80d993de7ecb89471c8b5ac9/c3975/Image-1.24.18-new-consumer-research-square.webp 200w,\n/static/d59b264d80d993de7ecb89471c8b5ac9/191d8/Image-1.24.18-new-consumer-research-square.webp 400w,\n/static/d59b264d80d993de7ecb89471c8b5ac9/e678a/Image-1.24.18-new-consumer-research-square.webp 800w","type":"image/webp","sizes":"(min-width: 800px) 800px, 100vw"}]},"width":800,"height":481.99999999999994}}}}}},{"categories":{"nodes":[{"name":"Agency News"}]},"title":"OMG!  The Internet Still Hasn’t Killed TV!","slug":"omg-the-internet-still-hasnt-killed-tv","featuredImage":{"node":{"localFile":{"childImageSharp":{"gatsbyImageData":{"layout":"constrained","placeholder":{"fallback":"data:image/jpeg;base64,"},"images":{"fallback":{"src":"/static/a045a286dc2f637de601de8d4f83c93b/3466b/The.Simpsons.S12E09.png","srcSet":"/static/a045a286dc2f637de601de8d4f83c93b/cd816/The.Simpsons.S12E09.png 160w,\n/static/a045a286dc2f637de601de8d4f83c93b/bbcb9/The.Simpsons.S12E09.png 320w,\n/static/a045a286dc2f637de601de8d4f83c93b/3466b/The.Simpsons.S12E09.png 640w","sizes":"(min-width: 640px) 640px, 100vw"},"sources":[{"srcSet":"/static/a045a286dc2f637de601de8d4f83c93b/ecab6/The.Simpsons.S12E09.webp 160w,\n/static/a045a286dc2f637de601de8d4f83c93b/87b13/The.Simpsons.S12E09.webp 320w,\n/static/a045a286dc2f637de601de8d4f83c93b/ea28b/The.Simpsons.S12E09.webp 640w","type":"image/webp","sizes":"(min-width: 640px) 640px, 100vw"}]},"width":640,"height":386}}}}}},{"categories":{"nodes":[{"name":"Agency News"}]},"title":"Advertising Age reports ad blocking and fraud is major concern","slug":"advertising-age-reports-ad-blocking-and-fraud-is-major-concern","featuredImage":{"node":{"localFile":{"childImageSharp":{"gatsbyImageData":{"layout":"constrained","placeholder":{"fallback":"data:image/jpeg;base64,"},"images":{"fallback":{"src":"/static/2dd08ccd62e28ad7682cd815679a886b/5329f/th.png","srcSet":"/static/2dd08ccd62e28ad7682cd815679a886b/be7c0/th.png 75w,\n/static/2dd08ccd62e28ad7682cd815679a886b/5d6b7/th.png 150w,\n/static/2dd08ccd62e28ad7682cd815679a886b/5329f/th.png 300w","sizes":"(min-width: 300px) 300px, 100vw"},"sources":[{"srcSet":"/static/2dd08ccd62e28ad7682cd815679a886b/8fa94/th.webp 75w,\n/static/2dd08ccd62e28ad7682cd815679a886b/cba1b/th.webp 150w,\n/static/2dd08ccd62e28ad7682cd815679a886b/93dd2/th.webp 300w","type":"image/webp","sizes":"(min-width: 300px) 300px, 100vw"}]},"width":300,"height":181}}}}}}]}}]}},"pageContext":{"id":"cG9zdDoxNTEy","content":"<p><span style=\"color: #000000;\"><span style=\"font-family: Helvetica, serif;\"><span style=\"font-size: large;\">by </span></span></span><a href=\"http://www.campaignlive.com/author/4705/Ilyse-Liffreing\"><span style=\"color: #000000;\"><span style=\"font-family: Helvetica, serif;\"><span style=\"font-size: large;\"><u>Ilyse Liffreing</u></span></span></span></a><br />\n&nbsp;<br />\n<span class=\" wp-image-1513 aligncenter inline-gatsby-image-wrapper gatsby-image-wrapper\" style=\"position:relative;overflow:hidden;max-width:100%;width:555px\" data-reactroot=\"\"><span aria-hidden=\"true\" style=\"width:100%;padding-bottom:66.18705035971223%\"></span><img aria-hidden=\"true\" src=\"data:image/png;base64,\" alt=\"\" style=\"position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;object-position:center;opacity:0;transition-delay:500ms\"/><picture><source srcSet=\"/static/b66889c3f102b541c11e9e193271bf3b/e1078/Screen-Shot-2017-04-18-at-2.54.14-PM.png 139w,\n/static/b66889c3f102b541c11e9e193271bf3b/3ea95/Screen-Shot-2017-04-18-at-2.54.14-PM.png 278w,\n/static/b66889c3f102b541c11e9e193271bf3b/1abaa/Screen-Shot-2017-04-18-at-2.54.14-PM.png 555w,\n/static/b66889c3f102b541c11e9e193271bf3b/dfb88/Screen-Shot-2017-04-18-at-2.54.14-PM.png 733w\" sizes=\"(max-width: 555px) 100vw, 555px\"/><img sizes=\"(max-width: 555px) 100vw, 555px\" srcSet=\"/static/b66889c3f102b541c11e9e193271bf3b/e1078/Screen-Shot-2017-04-18-at-2.54.14-PM.png 139w,\n/static/b66889c3f102b541c11e9e193271bf3b/3ea95/Screen-Shot-2017-04-18-at-2.54.14-PM.png 278w,\n/static/b66889c3f102b541c11e9e193271bf3b/1abaa/Screen-Shot-2017-04-18-at-2.54.14-PM.png 555w,\n/static/b66889c3f102b541c11e9e193271bf3b/dfb88/Screen-Shot-2017-04-18-at-2.54.14-PM.png 733w\" src=\"/static/b66889c3f102b541c11e9e193271bf3b/1abaa/Screen-Shot-2017-04-18-at-2.54.14-PM.png\" alt=\"Pre-Roll Ad Image\" loading=\"eager\" style=\"position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;object-position:center;opacity:1;transition:opacity 500ms\"/></picture><noscript><picture><source srcset=\"/static/b66889c3f102b541c11e9e193271bf3b/e1078/Screen-Shot-2017-04-18-at-2.54.14-PM.png 139w,\n/static/b66889c3f102b541c11e9e193271bf3b/3ea95/Screen-Shot-2017-04-18-at-2.54.14-PM.png 278w,\n/static/b66889c3f102b541c11e9e193271bf3b/1abaa/Screen-Shot-2017-04-18-at-2.54.14-PM.png 555w,\n/static/b66889c3f102b541c11e9e193271bf3b/dfb88/Screen-Shot-2017-04-18-at-2.54.14-PM.png 733w\" sizes=\"(max-width: 555px) 100vw, 555px\" /><img loading=\"eager\" sizes=\"(max-width: 555px) 100vw, 555px\" srcset=\"/static/b66889c3f102b541c11e9e193271bf3b/e1078/Screen-Shot-2017-04-18-at-2.54.14-PM.png 139w,\n/static/b66889c3f102b541c11e9e193271bf3b/3ea95/Screen-Shot-2017-04-18-at-2.54.14-PM.png 278w,\n/static/b66889c3f102b541c11e9e193271bf3b/1abaa/Screen-Shot-2017-04-18-at-2.54.14-PM.png 555w,\n/static/b66889c3f102b541c11e9e193271bf3b/dfb88/Screen-Shot-2017-04-18-at-2.54.14-PM.png 733w\" src=\"/static/b66889c3f102b541c11e9e193271bf3b/1abaa/Screen-Shot-2017-04-18-at-2.54.14-PM.png\" alt=\"Pre-Roll Ad Image\" style=\"position:absolute;top:0;left:0;opacity:1;width:100%;height:100%;object-fit:cover;object-position:center\"/></picture></noscript></span><br />\n&nbsp;<br />\nOf all video ad formats, pre-roll ads are not only the most memorable and engaging, but also the least interruptive, finds a new Magna study.<br />\n&nbsp;<br />\nThe IPG Mediabrands agency partnered with video advertising company <a href=\"http://www.yume.com/\"><span style=\"color: #fc0802;\"><span style=\"font-family: Helvetica, serif;\"><u>YuMe</u></span></span></a> to examine the impact various ad formats have on the user experience. The study tracked the behavioral metrics of 6,864 participants who viewed non-skippable pre-roll, mid-roll and the newer outstream ads (videos that play automatically when in full view) from either H&amp;M or Ghirardelli Chocolate across mobile and desktop screens.<br />\n&nbsp;<br />\nThe results, released on Monday in the report &#8220;The New Digital Video Landscape,&#8221; show that while users find all of the ad formats intrusive, pre-roll ads were the least interruptive. Only 17 percent of participants said they felt disrupted by pre-roll when watching content. However, the numbers surged for outstream ads: 60 percent of mobile users and 46 percent of desktop users said the format was disturbing. Still, mid-roll ads saw the most pushback, with 72 percent of mobile users and 53 percent of desktop users criticizing the format.<br />\n&nbsp;<br />\n<span class=\" wp-image-1514 aligncenter inline-gatsby-image-wrapper gatsby-image-wrapper\" style=\"position:relative;overflow:hidden;max-width:100%;width:676px\" data-reactroot=\"\"><span aria-hidden=\"true\" style=\"width:100%;padding-bottom:36.68639053254438%\"></span><img aria-hidden=\"true\" src=\"data:image/png;base64,\" alt=\"\" style=\"position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;object-position:center;opacity:0;transition-delay:500ms\"/><picture><source srcSet=\"/static/4d0b0d020ece368885b7e0c5a529a835/7c6b6/Screen-Shot-2017-04-18-at-2.55.21-PM.png 169w,\n/static/4d0b0d020ece368885b7e0c5a529a835/7264e/Screen-Shot-2017-04-18-at-2.55.21-PM.png 338w,\n/static/4d0b0d020ece368885b7e0c5a529a835/5860e/Screen-Shot-2017-04-18-at-2.55.21-PM.png 676w,\n/static/4d0b0d020ece368885b7e0c5a529a835/f3121/Screen-Shot-2017-04-18-at-2.55.21-PM.png 735w\" sizes=\"(max-width: 676px) 100vw, 676px\"/><img sizes=\"(max-width: 676px) 100vw, 676px\" srcSet=\"/static/4d0b0d020ece368885b7e0c5a529a835/7c6b6/Screen-Shot-2017-04-18-at-2.55.21-PM.png 169w,\n/static/4d0b0d020ece368885b7e0c5a529a835/7264e/Screen-Shot-2017-04-18-at-2.55.21-PM.png 338w,\n/static/4d0b0d020ece368885b7e0c5a529a835/5860e/Screen-Shot-2017-04-18-at-2.55.21-PM.png 676w,\n/static/4d0b0d020ece368885b7e0c5a529a835/f3121/Screen-Shot-2017-04-18-at-2.55.21-PM.png 735w\" src=\"/static/4d0b0d020ece368885b7e0c5a529a835/5860e/Screen-Shot-2017-04-18-at-2.55.21-PM.png\" alt=\"Pre-Roll Ad Research Chart\" loading=\"eager\" style=\"position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;object-position:center;opacity:1;transition:opacity 500ms\"/></picture><noscript><picture><source srcset=\"/static/4d0b0d020ece368885b7e0c5a529a835/7c6b6/Screen-Shot-2017-04-18-at-2.55.21-PM.png 169w,\n/static/4d0b0d020ece368885b7e0c5a529a835/7264e/Screen-Shot-2017-04-18-at-2.55.21-PM.png 338w,\n/static/4d0b0d020ece368885b7e0c5a529a835/5860e/Screen-Shot-2017-04-18-at-2.55.21-PM.png 676w,\n/static/4d0b0d020ece368885b7e0c5a529a835/f3121/Screen-Shot-2017-04-18-at-2.55.21-PM.png 735w\" sizes=\"(max-width: 676px) 100vw, 676px\" /><img loading=\"eager\" sizes=\"(max-width: 676px) 100vw, 676px\" srcset=\"/static/4d0b0d020ece368885b7e0c5a529a835/7c6b6/Screen-Shot-2017-04-18-at-2.55.21-PM.png 169w,\n/static/4d0b0d020ece368885b7e0c5a529a835/7264e/Screen-Shot-2017-04-18-at-2.55.21-PM.png 338w,\n/static/4d0b0d020ece368885b7e0c5a529a835/5860e/Screen-Shot-2017-04-18-at-2.55.21-PM.png 676w,\n/static/4d0b0d020ece368885b7e0c5a529a835/f3121/Screen-Shot-2017-04-18-at-2.55.21-PM.png 735w\" src=\"/static/4d0b0d020ece368885b7e0c5a529a835/5860e/Screen-Shot-2017-04-18-at-2.55.21-PM.png\" alt=\"Pre-Roll Ad Research Chart\" style=\"position:absolute;top:0;left:0;opacity:1;width:100%;height:100%;object-fit:cover;object-position:center\"/></picture></noscript></span><br />\n&nbsp;<br />\nAd recall was also the strongest for pre-roll ads. On mobile, 65 percent of participants were able to remember the brands they had seen in pre-rolls ads, compared to 39 percent of viewers of mid-roll ads and 28 percent of viewers of outstream ads. On desktop, the results were similar.<br />\n&nbsp;<br />\n<span class=\" wp-image-59128 aligncenter inline-gatsby-image-wrapper gatsby-image-wrapper\" style=\"position:relative;overflow:hidden;max-width:100%;width:682px\" data-reactroot=\"\"><span aria-hidden=\"true\" style=\"width:100%;padding-bottom:36.84210526315789%\"></span><img aria-hidden=\"true\" src=\"data:image/png;base64,\" alt=\"\" style=\"position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;object-position:center;opacity:0;transition-delay:500ms\"/><picture><source srcSet=\"/static/5660e62e1cf204cc07b2e62a476b8291/3f80a/Screen-Shot-2017-04-18-at-2.56.33-PM.png 171w,\n/static/5660e62e1cf204cc07b2e62a476b8291/005a8/Screen-Shot-2017-04-18-at-2.56.33-PM.png 341w,\n/static/5660e62e1cf204cc07b2e62a476b8291/e899a/Screen-Shot-2017-04-18-at-2.56.33-PM.png 682w,\n/static/5660e62e1cf204cc07b2e62a476b8291/8fb8e/Screen-Shot-2017-04-18-at-2.56.33-PM.png 732w\" sizes=\"(max-width: 682px) 100vw, 682px\"/><img sizes=\"(max-width: 682px) 100vw, 682px\" srcSet=\"/static/5660e62e1cf204cc07b2e62a476b8291/3f80a/Screen-Shot-2017-04-18-at-2.56.33-PM.png 171w,\n/static/5660e62e1cf204cc07b2e62a476b8291/005a8/Screen-Shot-2017-04-18-at-2.56.33-PM.png 341w,\n/static/5660e62e1cf204cc07b2e62a476b8291/e899a/Screen-Shot-2017-04-18-at-2.56.33-PM.png 682w,\n/static/5660e62e1cf204cc07b2e62a476b8291/8fb8e/Screen-Shot-2017-04-18-at-2.56.33-PM.png 732w\" src=\"/static/5660e62e1cf204cc07b2e62a476b8291/e899a/Screen-Shot-2017-04-18-at-2.56.33-PM.png\" alt=\"Pre-Roll Ad Research Chart\" loading=\"eager\" style=\"position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;object-position:center;opacity:1;transition:opacity 500ms\"/></picture><noscript><picture><source srcset=\"/static/5660e62e1cf204cc07b2e62a476b8291/3f80a/Screen-Shot-2017-04-18-at-2.56.33-PM.png 171w,\n/static/5660e62e1cf204cc07b2e62a476b8291/005a8/Screen-Shot-2017-04-18-at-2.56.33-PM.png 341w,\n/static/5660e62e1cf204cc07b2e62a476b8291/e899a/Screen-Shot-2017-04-18-at-2.56.33-PM.png 682w,\n/static/5660e62e1cf204cc07b2e62a476b8291/8fb8e/Screen-Shot-2017-04-18-at-2.56.33-PM.png 732w\" sizes=\"(max-width: 682px) 100vw, 682px\" /><img loading=\"eager\" sizes=\"(max-width: 682px) 100vw, 682px\" srcset=\"/static/5660e62e1cf204cc07b2e62a476b8291/3f80a/Screen-Shot-2017-04-18-at-2.56.33-PM.png 171w,\n/static/5660e62e1cf204cc07b2e62a476b8291/005a8/Screen-Shot-2017-04-18-at-2.56.33-PM.png 341w,\n/static/5660e62e1cf204cc07b2e62a476b8291/e899a/Screen-Shot-2017-04-18-at-2.56.33-PM.png 682w,\n/static/5660e62e1cf204cc07b2e62a476b8291/8fb8e/Screen-Shot-2017-04-18-at-2.56.33-PM.png 732w\" src=\"/static/5660e62e1cf204cc07b2e62a476b8291/e899a/Screen-Shot-2017-04-18-at-2.56.33-PM.png\" alt=\"Pre-Roll Ad Research Chart\" style=\"position:absolute;top:0;left:0;opacity:1;width:100%;height:100%;object-fit:cover;object-position:center\"/></picture></noscript></span><br />\n&nbsp;<br />\nPre-roll ads were found to be more engaging than other formats On mobile, 54 percent of consumers said pre-roll was engaging, while 44 percent said mid-roll and 37 percent said outstream. The results were similar on desktop.<br />\n&nbsp;<br />\n<span class=\" wp-image-59129 aligncenter inline-gatsby-image-wrapper gatsby-image-wrapper\" style=\"position:relative;overflow:hidden;max-width:100%;width:684px\" data-reactroot=\"\"><span aria-hidden=\"true\" style=\"width:100%;padding-bottom:36.84210526315789%\"></span><img aria-hidden=\"true\" src=\"data:image/png;base64,\" alt=\"\" style=\"position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;object-position:center;opacity:0;transition-delay:500ms\"/><picture><source srcSet=\"/static/0a2268c7f19a47a586ca4719e645dc4e/3f80a/Screen-Shot-2017-04-18-at-2.57.07-PM.png 171w,\n/static/0a2268c7f19a47a586ca4719e645dc4e/748c1/Screen-Shot-2017-04-18-at-2.57.07-PM.png 342w,\n/static/0a2268c7f19a47a586ca4719e645dc4e/921db/Screen-Shot-2017-04-18-at-2.57.07-PM.png 684w,\n/static/0a2268c7f19a47a586ca4719e645dc4e/2d0a6/Screen-Shot-2017-04-18-at-2.57.07-PM.png 730w\" sizes=\"(max-width: 684px) 100vw, 684px\"/><img sizes=\"(max-width: 684px) 100vw, 684px\" srcSet=\"/static/0a2268c7f19a47a586ca4719e645dc4e/3f80a/Screen-Shot-2017-04-18-at-2.57.07-PM.png 171w,\n/static/0a2268c7f19a47a586ca4719e645dc4e/748c1/Screen-Shot-2017-04-18-at-2.57.07-PM.png 342w,\n/static/0a2268c7f19a47a586ca4719e645dc4e/921db/Screen-Shot-2017-04-18-at-2.57.07-PM.png 684w,\n/static/0a2268c7f19a47a586ca4719e645dc4e/2d0a6/Screen-Shot-2017-04-18-at-2.57.07-PM.png 730w\" src=\"/static/0a2268c7f19a47a586ca4719e645dc4e/921db/Screen-Shot-2017-04-18-at-2.57.07-PM.png\" alt=\"Pre-Roll Ad Research Chart\" loading=\"eager\" style=\"position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;object-position:center;opacity:1;transition:opacity 500ms\"/></picture><noscript><picture><source srcset=\"/static/0a2268c7f19a47a586ca4719e645dc4e/3f80a/Screen-Shot-2017-04-18-at-2.57.07-PM.png 171w,\n/static/0a2268c7f19a47a586ca4719e645dc4e/748c1/Screen-Shot-2017-04-18-at-2.57.07-PM.png 342w,\n/static/0a2268c7f19a47a586ca4719e645dc4e/921db/Screen-Shot-2017-04-18-at-2.57.07-PM.png 684w,\n/static/0a2268c7f19a47a586ca4719e645dc4e/2d0a6/Screen-Shot-2017-04-18-at-2.57.07-PM.png 730w\" sizes=\"(max-width: 684px) 100vw, 684px\" /><img loading=\"eager\" sizes=\"(max-width: 684px) 100vw, 684px\" srcset=\"/static/0a2268c7f19a47a586ca4719e645dc4e/3f80a/Screen-Shot-2017-04-18-at-2.57.07-PM.png 171w,\n/static/0a2268c7f19a47a586ca4719e645dc4e/748c1/Screen-Shot-2017-04-18-at-2.57.07-PM.png 342w,\n/static/0a2268c7f19a47a586ca4719e645dc4e/921db/Screen-Shot-2017-04-18-at-2.57.07-PM.png 684w,\n/static/0a2268c7f19a47a586ca4719e645dc4e/2d0a6/Screen-Shot-2017-04-18-at-2.57.07-PM.png 730w\" src=\"/static/0a2268c7f19a47a586ca4719e645dc4e/921db/Screen-Shot-2017-04-18-at-2.57.07-PM.png\" alt=\"Pre-Roll Ad Research Chart\" style=\"position:absolute;top:0;left:0;opacity:1;width:100%;height:100%;object-fit:cover;object-position:center\"/></picture></noscript></span><br />\n&nbsp;<br />\nThe findings reveal that consumers are most critical when viewing ads on their personal mobile devices. &#8220;To take advantage of higher purchase intent for all ad formats,&#8221; the study notes, &#8220;ads must be less intrusive and more engaging to keep attention.&#8221;</p>\n","title":"Pre-roll ads are the least interruptive, finds IPG study","seo":{"breadcrumbs":[{"text":"Pre-roll ads are the least interruptive, finds IPG study","url":"/pre-roll-ads-are-the-least-interruptive-finds-ipg-study/"}],"title":"Pre-roll Ads are Least Interruptive - IPG Study | The PM Group","metaDesc":"In a new study examining various ad formats, pre-roll ads were perceived to be the least interruptive to users. What about the other video formats?","focuskw":"pre-roll ads","metaKeywords":"","metaRobotsNoindex":"index","metaRobotsNofollow":"follow","opengraphTitle":"Pre-roll Ads are Least Interruptive - IPG Study | The PM Group","opengraphDescription":"In a new study examining vario